# ===========================================
# moltis + n8n Stack Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Core Secrets
# ===========================================
LITELLM_API_KEY=sk-...your-key-here...
MOLTIS_PASSWORD=
MCP_CONTEXT7_API_KEY=

# ===========================================
# PostgreSQL (shared: n8n workflows, litellm, baserow)
# ===========================================
DB_USER=app_user
DB_PASSWORD=app_pass
DB_NAME=app_db
LITELLM_DB=litellm
BASEROW_DB=baserow

# ===========================================
# Baserow
# ===========================================
BASEROW_VERSION=2.1.3
BASEROW_SECRET_KEY=change-me-baserow-secret-key
BASEROW_JWT_SIGNING_KEY=change-me-baserow-jwt-signing-key
BASEROW_REDIS_PASSWORD=change-me-baserow-redis-password
BASEROW_DOMAIN=baserow.example.com

# ===========================================
# n8n
# ===========================================
N8N_ENCRYPTION_KEY=
N8N_PORT=5678

# ===========================================
# Traefik / Domains
# ===========================================
PROXY_DOMAIN=example.com
PROXY_EMAIL=admin@example.com

# ===========================================
# General
# ===========================================
TIMEZONE=Etc/UTC
